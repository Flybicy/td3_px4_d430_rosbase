<launch>
    <arg name="map_size_x" default="200.0"/>
    <arg name="map_size_y" default="200.0"/>
    <arg name="map_size_z" default="3.0"/>
    <arg name="odom_topic" default="visual_slam/odom"/>
    <arg name="drone_id" default="0"/>
    <arg name="init_x" default="-15.0"/>
    <arg name="init_y" default="0.0"/>
    <arg name="init_z" default="1.0"/>

    <arg name="policy_backend" default="heuristic"/>
    <arg name="model_path" default=""/>
    <arg name="command_mode" default="position_velocity"/>
    <arg name="rate" default="20.0"/>
    <arg name="max_vel" default="1.5"/>
    <arg name="max_acc" default="2.0"/>
    <arg name="max_z_vel" default="0.5"/>
    <arg name="world_size" default="20.0"/>
    <arg name="yaw_rays" default="12"/>
    <arg name="pitch_rays" default="3"/>
    <arg name="sensor_range" default="5.0"/>
    <arg name="max_cloud_points" default="1200"/>
    <arg name="debug" default="false"/>
    <arg name="z_min" default="0.3"/>
    <arg name="z_max" default="2.8"/>
    <arg name="goal_z_min" default="0.3"/>
    <arg name="default_goal_z" default="1.0"/>
    <arg name="keep_current_z_if_goal_low" default="true"/>

    <node pkg="map_generator" name="random_forest" type="random_forest" output="screen">
        <param name="map/x_size" value="26"/>
        <param name="map/y_size" value="20"/>
        <param name="map/z_size" value="3"/>
        <param name="map/resolution" value="0.1"/>
        <param name="ObstacleShape/seed" value="1"/>
        <param name="map/obs_num" value="100"/>
        <param name="ObstacleShape/lower_rad" value="0.5"/>
        <param name="ObstacleShape/upper_rad" value="0.7"/>
        <param name="ObstacleShape/lower_hei" value="0.0"/>
        <param name="ObstacleShape/upper_hei" value="3.0"/>
        <param name="map/circle_num" value="100"/>
        <param name="ObstacleShape/radius_l" value="0.7"/>
        <param name="ObstacleShape/radius_h" value="0.5"/>
        <param name="ObstacleShape/z_l" value="0.7"/>
        <param name="ObstacleShape/z_h" value="0.8"/>
        <param name="ObstacleShape/theta" value="0.5"/>
        <param name="pub_rate" value="1.0"/>
        <param name="min_distance" value="0.8"/>
    </node>

    <include file="$(find diff_planner)/launch/include/simulator.xml">
        <arg name="drone_id" value="$(arg drone_id)"/>
        <arg name="map_size_x_" value="$(arg map_size_x)"/>
        <arg name="map_size_y_" value="$(arg map_size_y)"/>
        <arg name="map_size_z_" value="$(arg map_size_z)"/>
        <arg name="init_x_" value="$(arg init_x)"/>
        <arg name="init_y_" value="$(arg init_y)"/>
        <arg name="init_z_" value="$(arg init_z)"/>
        <arg name="odometry_topic" value="$(arg odom_topic)"/>
    </include>

    <node pkg="diff_planner" name="drone_$(arg drone_id)_td3_velocity_planner" type="td3_velocity_planner.py" output="screen">
        <param name="drone_id" value="$(arg drone_id)"/>
        <param name="policy_backend" value="$(arg policy_backend)"/>
        <param name="model_path" value="$(arg model_path)"/>
        <param name="command_mode" value="$(arg command_mode)"/>
        <param name="rate" value="$(arg rate)"/>
        <param name="max_vel" value="$(arg max_vel)"/>
        <param name="max_acc" value="$(arg max_acc)"/>
        <param name="max_z_vel" value="$(arg max_z_vel)"/>
        <param name="world_size" value="$(arg world_size)"/>
        <param name="yaw_rays" value="$(arg yaw_rays)"/>
        <param name="pitch_rays" value="$(arg pitch_rays)"/>
        <param name="sensor_range" value="$(arg sensor_range)"/>
        <param name="max_cloud_points" value="$(arg max_cloud_points)"/>
        <param name="debug" value="$(arg debug)"/>
        <param name="z_min" value="$(arg z_min)"/>
        <param name="z_max" value="$(arg z_max)"/>
        <param name="goal_z_min" value="$(arg goal_z_min)"/>
        <param name="default_goal_z" value="$(arg default_goal_z)"/>
        <param name="keep_current_z_if_goal_low" value="$(arg keep_current_z_if_goal_low)"/>
        <remap from="odom" to="/drone_$(arg drone_id)_$(arg odom_topic)"/>
        <remap from="goal" to="/goal"/>
    <!-- Use the depth-camera-rendered local point cloud, not the full global map. -->
    <remap from="obstacle_cloud" to="/drone_$(arg drone_id)_pcl_render_node/rendered_pcl"/>
        <remap from="position_cmd" to="/drone_$(arg drone_id)_planning/pos_cmd"/>
    </node>

    <include file="$(find manual_take_over)/launch/take_over_drone.launch">
        <arg name="drone_id" value="$(arg drone_id)"/>
        <arg name="cmd_topic" value="drone_$(arg drone_id)_planning/pos_cmd"/>
    </include>

    <node name="rviz" pkg="rviz" type="rviz" args="-d $(find diff_planner)/launch/include/sim.rviz" required="true"/>
</launch>
